filters:
  and:
    - note["base"] == link("Pursuit.base")
properties:
  file.name:
    displayName: Name
  Shuffle:
    displayName: Shuffle
  Pile:
    displayName: Pile
  Date Added:
    displayName: Date Added
  Alarm:
    displayName: Alarm
views:
  - type: table
    name: Table View
    order:
      - file.name
      - Shuffle
      - Pile
      - Date Added
      - Alarm
